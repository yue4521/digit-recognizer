# 環境設定ファイルの例
# 実際の本番環境では適切な値を設定してください

# サーバー設定
PORT=5002
NODE_ENV=development

# セキュリティ設定
API_KEY=change-this-to-a-secure-random-key-in-production
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Python設定
PYTHON_PATH=python3

# SSL証明書設定（macOS環境で必要な場合）
# SSL_CERT_FILE=/usr/local/lib/python3.13/site-packages/certifi/cacert.pem
# REQUESTS_CA_BUNDLE=/usr/local/lib/python3.13/site-packages/certifi/cacert.pem

# ML設定
# 本番環境では実際のモデルファイルのハッシュ値を設定
# ALLOWED_MODEL_HASHES=sha256_hash_of_your_model_file

# ログ設定（本番環境用）
LOG_LEVEL=info
LOG_FILE_PATH=/var/log/digit-recognizer/app.log

# データベース設定（将来の拡張用）
# DATABASE_URL=postgres://user:pass@localhost:5432/digitrec